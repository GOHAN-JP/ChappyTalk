<Window x:Class="ChappyTalk.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙️ 設定" Height="680" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- システムプロンプト -->
                <TextBlock Text="💬 システムプロンプト" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="SystemPromptBox" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True" 
                         Height="150"
                         VerticalScrollBarVisibility="Auto"/>
                <TextBlock Text="AIの性格や口調を指定できます（空欄でデフォルト）" 
                           Foreground="Gray" FontSize="11" Margin="0,2,0,10"/>

                <!-- APIキー -->
                <TextBlock Text="🔑 OpenAI APIキー" FontWeight="Bold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="ApiKeyBox" Height="28"/>
                <TextBlock Text="sk-proj-... で始まるキー" 
                           Foreground="Gray" FontSize="11" Margin="0,2,0,10"/>

                <!-- AIVIS URL -->
                <TextBlock Text="🔊 AIVIS URL" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="AivisUrlBox" Height="28"/>
                <Separator Margin="0,10"/>

                <!-- 音声速度 -->
                <TextBlock FontWeight="Bold" Margin="0,5,0,5">
                    <Run Text="⏩ 音声速度: "/><Run x:Name="SpeedLabel" Text="1.1"/>
                </TextBlock>
                <Slider x:Name="SpeedSlider" 
                        Minimum="0.5" Maximum="2.0" 
                        TickFrequency="0.1" IsSnapToTickEnabled="True"
                        ValueChanged="SpeedSlider_ValueChanged"/>

                <!-- ピッチ -->
                <TextBlock FontWeight="Bold" Margin="0,5,0,5">
                    <Run Text="🎵 ピッチ: "/><Run x:Name="PitchLabel" Text="0.0"/>
                </TextBlock>
                <Slider x:Name="PitchSlider" 
                        Minimum="-0.15" Maximum="0.15" 
                        TickFrequency="0.01" IsSnapToTickEnabled="True"
                        ValueChanged="PitchSlider_ValueChanged"/>

                <!-- 抑揚 -->
                <TextBlock FontWeight="Bold" Margin="0,5,0,5">
                    <Run Text="🎭 抑揚: "/><Run x:Name="IntonationLabel" Text="1.2"/>
                </TextBlock>
                <Slider x:Name="IntonationSlider" 
                        Minimum="0.0" Maximum="2.0" 
                        TickFrequency="0.1" IsSnapToTickEnabled="True"
                        ValueChanged="IntonationSlider_ValueChanged"/>

                <Separator Margin="0,10"/>

                <!-- 無音検出感度 -->
                <TextBlock FontWeight="Bold" Margin="0,5,0,5">
                    <Run Text="🎤 無音検出感度: "/><Run x:Name="SilenceLabel" Text="0.02"/>
                </TextBlock>
                <Slider x:Name="SilenceSlider" 
                        Minimum="0.005" Maximum="0.1" 
                        TickFrequency="0.005" IsSnapToTickEnabled="True"
                        ValueChanged="SilenceSlider_ValueChanged"/>
                <TextBlock Text="小さい値 = 感度が高い（静かな環境向け）" 
                           Foreground="Gray" FontSize="11" Margin="0,2,0,5"/>

                <!-- エコー防止待機 -->
                <TextBlock FontWeight="Bold" Margin="0,5,0,5">
                    <Run Text="🔇 エコー防止待機: "/><Run x:Name="EchoLabel" Text="300"/><Run Text="ms"/>
                </TextBlock>
                <Slider x:Name="EchoSlider" 
                        Minimum="100" Maximum="2000" 
                        TickFrequency="100" IsSnapToTickEnabled="True"
                        ValueChanged="EchoSlider_ValueChanged"/>
                <TextBlock Text="Bluetoothスピーカーの場合は大きめに" 
                           Foreground="Gray" FontSize="11" Margin="0,2,0,5"/>

                <!-- 会話履歴保持数 -->
                <TextBlock FontWeight="Bold" Margin="0,5,0,5">
                    <Run Text="📝 会話履歴保持: "/><Run x:Name="HistoryLabel" Text="3"/><Run Text="ターン"/>
                </TextBlock>
                <Slider x:Name="HistorySlider" 
                        Minimum="1" Maximum="10" 
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="HistorySlider_ValueChanged"/>
                <TextBlock Text="多いほど文脈を覚えるが料金が増えます" 
                           Foreground="Gray" FontSize="11" Margin="0,2,0,10"/>

                <Separator Margin="0,10"/>

                <!-- フォントサイズ -->
                <TextBlock FontWeight="Bold" Margin="0,5,0,5">
                    <Run Text="🔤 フォントサイズ: "/><Run x:Name="FontSizeLabel" Text="18"/><Run Text="pt"/>
                </TextBlock>
                <Slider x:Name="FontSizeSlider" 
                        Minimum="10" Maximum="30" 
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="FontSizeSlider_ValueChanged"/>
                <TextBlock Text="YouTube配信なら18〜20ptがおすすめ" 
                           Foreground="Gray" FontSize="11" Margin="0,2,0,10"/>

                <!-- 為替レート -->
                <TextBlock FontWeight="Bold" Margin="0,5,0,5">
                    <Run Text="💱 為替レート（USD→JPY）: "/>
                </TextBlock>
                <TextBox x:Name="UsdToJpyBox" Height="28" Width="100" HorizontalAlignment="Left"/>
                <TextBlock Text="トークン料金の円換算に使用（例: 150）" 
                           Foreground="Gray" FontSize="11" Margin="0,2,0,10"/>

                <!-- 予算上限 -->
                <TextBlock FontWeight="Bold" Margin="0,5,0,5">
                    <Run Text="⚠️ 予算上限（円）: "/>
                </TextBlock>
                <TextBox x:Name="BudgetLimitBox" Height="28" Width="100" HorizontalAlignment="Left"/>
                <TextBlock Text="累計料金がこの金額を超えると警告（0=無制限）" 
                           Foreground="Gray" FontSize="11" Margin="0,2,0,10"/>

                <Separator Margin="0,10"/>

                <!-- ログ自動保存 -->
                <CheckBox x:Name="AutoSaveLogCheck" 
                          Content="📝 アプリ終了時にログを自動保存" 
                          FontWeight="Bold"
                          Margin="0,5,0,5"/>

            </StackPanel>
        </ScrollViewer>

        <!-- ボタン -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="キャンセル" Width="90" Height="30" Click="Cancel_Click" Margin="0,0,10,0"/>
            <Button Content="💾 保存" Width="90" Height="30" Click="Save_Click" 
                    Background="LightGreen" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
